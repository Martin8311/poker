# 复制为 .env 后按需修改；docker-compose 会自动读取本目录下的 .env。
# 注意：本机用 IDE 直接运行应用时，请在「运行配置 → 环境变量」里设置相同的
#       DB_PASSWORD / REDIS_* 等，使应用与容器中间件的配置保持一致。

# ===== MySQL =====
MYSQL_ROOT_PASSWORD=poker_root_pwd

# ===== 应用连接数据库（需与 MYSQL_ROOT_PASSWORD 一致）=====
DB_USERNAME=root
DB_PASSWORD=poker_root_pwd

# ===== Redis（本地默认无密码）=====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===== RabbitMQ / WebSocket Broker Relay =====
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_HOST=localhost
RABBITMQ_STOMP_PORT=61613
# 设为 true 启用 RabbitMQ 集群模式（需先 docker compose up -d rabbitmq）
WS_RELAY_ENABLED=false
